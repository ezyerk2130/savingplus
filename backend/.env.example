# SavingPlus Backend Configuration

# Server
SERVER_PORT=8080
ADMIN_SERVER_PORT=8081
ENV=development
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=savingplus
DB_PASSWORD=savingplus_secret
DB_NAME=savingplus
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# Encryption (AES-256 key, 32 bytes hex-encoded)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# OTP
OTP_LENGTH=6
OTP_TTL=300

# Rate Limiting
RATE_LIMIT_PER_SECOND=5
RATE_LIMIT_PER_MINUTE=100

# Mobile Money / Payment Gateway
PAYMENT_GATEWAY=mock
CELLULANT_API_URL=https://api.cellulant.com
CELLULANT_API_KEY=
CELLULANT_API_SECRET=
CELLULANT_CALLBACK_URL=http://localhost:8080/api/v1/webhooks/payment

# Africa's Talking (SMS)
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=SavingPlus

# SendGrid (Email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@savingplus.co.tz
SENDGRID_FROM_NAME=SavingPlus

# Firebase Cloud Messaging
FCM_SERVER_KEY=

# TOTP (Admin MFA)
TOTP_ISSUER=SavingPlus

# Step-up Auth Threshold (TZS)
STEPUP_THRESHOLD=100000
